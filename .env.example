# ============================================
# Environment Variables
# ============================================
# Copy file này thành .env và điền giá trị của bạn.
# NEVER commit .env to git!
#
# Biến được nhóm theo module sở hữu nó. Backend và ai đọc chung file .env này
# nhưng mỗi bên chỉ parse phần của mình (xem ai/config.py và backend/config.py).

# ============================================
# Module: ai/  (ai/src/ai/config.py)
# ============================================

# ---- LLM ----
OPENAI_API_KEY=sk-your-key-here
MODEL_NAME=gpt-4o-mini
LLM_TEMPERATURE=0.7

# ---- AI application logging ----
# JSON suits Docker/production; text is easier to read during local debugging.
# Logs contain metadata only, never query or prompt content.
AI_LOG_LEVEL=INFO
AI_LOG_FORMAT=json
# Hoặc provider khác:
# ANTHROPIC_API_KEY=
# GOOGLE_API_KEY=

# ---- Vector Store ----
CHROMA_PERSIST_DIR=./data/chroma
# Hoặc Pinecone:
# PINECONE_API_KEY=
# PINECONE_ENVIRONMENT=

# ============================================
# Module: backend/  (backend/src/backend/config.py)
# ============================================

APP_ENV=development
APP_PORT=8000
APP_HOST=0.0.0.0
LOG_LEVEL=INFO

# Domain của frontend — phân tách bằng dấu phẩy
CORS_ORIGINS=http://localhost:3000

# ---- Database ----
DATABASE_URL=sqlite:///./data/app.db
# Production:
# DATABASE_URL=postgresql://user:password@localhost:5432/dbname

# ---- AI ----
# Không còn biến nào: AI chạy in-process trong backend (package `ai` được cài kèm),
# không phải service riêng nên không có URL/timeout. Model đọc từ ai/models/model.pkl —
# sinh bằng `python ai/scripts/train.py`.

# ============================================
# Module: frontend/
# ============================================
# LƯU Ý: biến NEXT_PUBLIC_* được nhúng vào bundle LÚC BUILD, không phải lúc chạy.
# Khi dev thì đặt trong frontend/.env.local; khi build Docker thì truyền qua build arg.
# NEXT_PUBLIC_API_URL=http://localhost:8000

# ============================================
# Dùng chung
# ============================================

# ---- LangSmith — trace agent khi debug ----
# Để trống LANGCHAIN_TRACING_V2 nếu không muốn gửi trace đi đâu cả.
LANGCHAIN_API_KEY=your-langsmith-key-here
LANGCHAIN_PROJECT=viber-coding-pro-max
LANGCHAIN_TRACING_V2=true

# ---- PostgreSQL & Redis (Docker / Local) ----
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=srrm
REDIS_URL=redis://localhost:6379/0
